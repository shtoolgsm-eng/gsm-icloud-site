<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login - GSM SHTOOL VIP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --gold: #c5a059; --bg: #05070a; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); color: white; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .login-card { width: 100%; max-width: 400px; padding: 40px; background: rgba(255,255,255,0.02); backdrop-filter: blur(20px); border-radius: 30px; border: 1px solid rgba(255,255,255,0.1); text-align: center; }
        .login-card h2 { color: var(--gold); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 30px; }
        .premium-input { width: 100%; padding: 15px; background: #111; border: 1px solid #333; border-radius: 12px; color: white; outline: none; box-sizing: border-box; margin-bottom: 20px; }
        .login-btn { width: 100%; padding: 15px; background: var(--gold); color: black; border: none; border-radius: 12px; font-weight: 900; cursor: pointer; transition: 0.3s; text-transform: uppercase; }
        .login-btn:hover { transform: scale(1.02); box-shadow: 0 0 20px rgba(197, 160, 89, 0.3); }
    </style>
</head>
<body>
    <div class="login-card">
        <i class="fas fa-user-shield" style="font-size: 3rem; color: var(--gold); margin-bottom: 20px;"></i>
        <h2>VIP Access</h2>
        <form onsubmit="handleLogin(event)">
            <input type="text" id="userField" class="premium-input" placeholder="Enter Username" required>
            <input type="password" class="premium-input" placeholder="Password" required>
            <button type="submit" class="login-btn">Login to Panel</button>
        </form>
    </div>

    <script>
        function handleLogin(e) {
            e.preventDefault();
            const user = document.getElementById('userField').value;
            localStorage.setItem('gsm_user', user);
            window.location.href = 'dashboard.html';
        }
    </script>
</body>
</html>
